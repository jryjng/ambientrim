<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Campfire"]/comps</xpath>
		<value>
			<li Class="ambient.CompProperties_FueledSound"/>
		</value>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Ambient Rim</li>
		</mods>
		<match Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Royalty">
				<xpath>Defs/ThingDef[defName="Brazier"]/comps</xpath>
				<value>
					<li Class="ambient.CompProperties_FueledSound"/>
				</value>
			</li>
			<li Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Royalty">
				<xpath>Defs/ThingDef[defName="DarklightBrazier"]/comps</xpath>
				<value>
					<li Class="ambient.CompProperties_FueledSound"/>
				</value>
			</li>
		</operations>
		</match>
	</Operation>
</Patch>